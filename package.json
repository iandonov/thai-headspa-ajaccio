{
	"name": "spa",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:report": "playwright show-report",
		"deploy-azure": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-azure.ps1",
		"deploy-azure:fast": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/deploy-azure.ps1 -Fast"
	},
	"devDependencies": {
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.64.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"drizzle-kit": "^0.31.10",
		"postcss": "^8.5.15",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@types/better-sqlite3": "^7.6.13",
		"bcryptjs": "^3.0.3",
		"better-sqlite3": "^12.10.0",
		"drizzle-orm": "^0.45.2",
		"jose": "^6.2.3"
	}
}
